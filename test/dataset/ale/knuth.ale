fun knuth_test (n) = {
    sum = 0;
    i = 1;
    (i <= n)?*{
        sum = sum + i * i;
        i = i + 1
    };
    sum
};

fun knuth_recursive (n, current, sum) = {
    (current > n)?{
        sum
    }:{
        knuth_recursive(n, current + 1, sum + current * current)
    }
};

fun knuth_rec (n) = {
    knuth_recursive(n, 1, 0)
};

fun knuth_formula (n) = {
    n * (n + 1) * (2 * n + 1) / 6
};

print(knuth_test(1000));
print(knuth_rec(1000));
print(knuth_formula(1000));
